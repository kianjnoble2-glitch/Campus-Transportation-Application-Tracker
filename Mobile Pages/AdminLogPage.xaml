<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:gauge="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
            xmlns:popup="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
             xmlns:cards="clr-namespace:Syncfusion.Maui.Cards;assembly=Syncfusion.Maui.Cards"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"     
             x:Class="Kats.AdminLogPage" 
             BackgroundColor="#fadfdf"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             >
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="1,0" EndPoint="1.5,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Color="#fadfdf" Offset="0.45" />
                    <GradientStop Color="#FFFFFF" Offset="0.77" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>
    </ContentPage.Background>


    <Grid RowDefinitions="Auto, Auto, Auto, *" ColumnDefinitions="*">
        <!-- Gradient background using multiple frames -->

        <StackLayout Grid.Row="0"
             Orientation="Vertical"
             HorizontalOptions="StartAndExpand"
             VerticalOptions="Center"
             Spacing="0"
             Margin="20">

            <Label Text="WELCOME TO"
                HorizontalOptions="StartAndExpand"
                VerticalOptions="Center"
                TextColor="#1e4072"
                FontSize="18"
                FontFamily="Arial"
                FontAttributes="Bold"
                />
            <Label Text="X BUS"
                HorizontalOptions="StartAndExpand"
                VerticalOptions="Center"
                TextColor="#c3645f"
                FontSize="24"
                FontFamily="Segoe UI"
                FontAttributes="Bold"
                />

        </StackLayout>

        <StackLayout Grid.Row="1">
            <Image Source="bus.png" 
        HorizontalOptions="Center"
        VerticalOptions="Center"
        WidthRequest="400"
        HeightRequest="350"
        />
            <Frame WidthRequest="110"
            HeightRequest="110"
            CornerRadius="55"
            BorderColor="#d28b87"
            BackgroundColor="#d28b87"
            Padding="0"
            HorizontalOptions="Center">
                <Frame WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="50"
                        BackgroundColor="#e1b1af"
                        Padding="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Label Text="PARENTS"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TextColor="#1e4072"
                FontSize="18"
                FontAttributes="Bold"
                />
                </Frame>
            </Frame>

        </StackLayout>

        <Grid Grid.Row="2" >

            <!-- Logo at the center -->
            <cards:SfCardLayout  HeightRequest="400"   BackgroundColor="Transparent" >
                <StackLayout Padding="20" Spacing="5" >
                    <!-- Username Entry with Border -->
                    <Frame BackgroundColor="Transparent"
                   BorderColor="#8F1D1D"
                   CornerRadius="5"
                   Padding="0"
                   HasShadow="False"
                   Margin="0,0">
                        <Entry  x:Name="EmailEntry" Placeholder="CODE **"
                   BackgroundColor="white"
                   TextColor="DarkBlue"
                   FontAttributes="Bold"
                   PlaceholderColor="#E86E41"
                   HorizontalOptions="FillAndExpand"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   Margin="0"                       
                  />
                    </Frame>

                    <Frame BackgroundColor="Transparent"
                   BorderColor="#333333"
                   CornerRadius="5"
                   Padding="0"
                   HasShadow="False"
                   Margin="0,0">
                        <Entry x:Name="PasswordEntry" Placeholder="PASSWORD**"
                   IsPassword="True"
                   FontAttributes="Bold"
                   BackgroundColor="white"
                   TextColor="DarkBlue"
                   PlaceholderColor="#E86E41"
                   HorizontalOptions="FillAndExpand"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   Margin="0"  
                   />
                    </Frame>

                    <!-- Sign In Button -->
                    <Button Text="Sign In"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center"
                            BackgroundColor="#4FB7D9"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="10"
                            Margin="0,5"
                            Clicked="OnLoginButtonClicked"/>

                </StackLayout>
            </cards:SfCardLayout>
        </Grid>


    </Grid>

</ContentPage>
