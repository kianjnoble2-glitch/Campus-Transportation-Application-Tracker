<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AdminApp.LoginPage"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             Shell.FlyoutBehavior="Disabled">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"
                            IsEnabled="False" />
    </Shell.BackButtonBehavior>
    
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#060038"
                          Offset="0.0" />
            <GradientStop Color="Black"
                          Offset="0.1" />
            <GradientStop Color="#0E0027"
                          Offset="0.45" />
            <GradientStop Color="Black"
                          Offset="0.55" />
            <GradientStop Color="#060038"
                          Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="gradient"
                                 EndPoint="0,1">
                <GradientStop Offset="0"
                              Color="#0b0c1e" />
                <GradientStop Offset="0"
                              Color="#0b0c1e" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid HorizontalOptions="Center"
          VerticalOptions="Center">

        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="20" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="12"
                Padding="0"
                Margin="0"
                BackgroundColor="#0b0c1e"
                Stroke="#0b0c1e"
                StrokeThickness="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="40,40,40,40" />
            </Border.StrokeShape>
            <Image Source="plant3.jpg"
                   Aspect="AspectFit" />
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.RowSpan="10"
                Grid.ColumnSpan="5"
                StrokeThickness="0"
                Opacity="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,40,0,40" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush>
                    <GradientStop Color="#191d4d"
                                  Offset="0" />
                    <GradientStop Color="Black"
                                  Offset="0.1" />
                    <GradientStop Color="#0b0c1e"
                                  Offset="0.8" />
                    <GradientStop Color="#191d4d"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Label Grid.Row="2"
               Grid.Column="1"
               Grid.ColumnSpan="5"
               Text="Login"
               TextColor="#dbc6d9"
               FontSize="25"
               FontAttributes="Bold"
               HorizontalOptions="Center" />
        <Border Grid.Row="3"
                Grid.Column="2"
                Grid.ColumnSpan="3"
                BackgroundColor="Transparent">
            <Grid ColumnDefinitions="60,Auto,*">
                <Label Grid.Column="0"
                       Text="Email: "
                       TextColor="White"
                       Padding="10"
                       VerticalOptions="Center"
                       HorizontalOptions="StartAndExpand" />
                <Entry Placeholder="Enter your text here..."
                       x:Name="EmailEntry"
                       Grid.Column="1"
                       HorizontalOptions="StartAndExpand"
                       WidthRequest="250" />
                <Image Source="email.png"
                       Grid.Column="2"
                       Margin="10"
                       HorizontalOptions="End"
                       WidthRequest="20"
                       HeightRequest="20" />
            </Grid>
        </Border>
        <Border Grid.Row="5"
                Grid.Column="2"
                Grid.ColumnSpan="3"
                BackgroundColor="Transparent">
            <Grid ColumnDefinitions="90,Auto,*">
                <Label Grid.Column="0"
                       Text="Password: "
                       TextColor="White"
                       Padding="10"
                       VerticalOptions="Center"
                       HorizontalOptions="StartAndExpand" />
                <Entry Placeholder="Enter your text here..."
                       x:Name="PasswordEntry"
                       Grid.Column="1"
                       HorizontalOptions="StartAndExpand"
                       WidthRequest="220" 
                       IsPassword="True"/>
                <Image Source="password.png"
                       Grid.Column="2"
                       Margin="10"
                       HorizontalOptions="End"
                       WidthRequest="20"
                       HeightRequest="20" />
            </Grid>
        </Border>
        <buttons:SfButton Text="Login"
                          TextColor="Black"
                          Grid.Column="2"
                          Grid.Row="7"
                          Grid.ColumnSpan="3"
                          FontAttributes="Bold"
                          FontSize="20"
                          x:Name="loginButton"
                          Clicked="OnLoginButtonClicked" />
    </Grid>
</ContentPage>