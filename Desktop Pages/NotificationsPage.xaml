                                                                                  Data="M 0,0 L 36,0 36,36Z"
                                                                                  Fill="#0e79d7"
                                                                                  Stroke="Gray" />
                                                                            <VerticalStackLayout Spacing="2"
                                                                                                 Margin="10,0,0,0"
                                                                                                 HorizontalOptions="Start">
                                                                                <Label Text="{Binding Title}"
                                                                                       TextColor="Black"
                                                                                       CharacterSpacing=".25"
                                                                                       FontSize="20"
                                                                                       FontAttributes="Bold"
                                                                                       VerticalOptions="Center"
                                                                                       HorizontalOptions="Start" />
                                                                                <Label Text="{Binding Description}"
                                                                                       TextColor="DarkGray"
                                                                                       FontSize="12"
                                                                                       FontAttributes="Bold"
                                                                                       VerticalOptions="Center"
                                                                                       HorizontalOptions="Start" />
                                                                            </VerticalStackLayout>
                                                                            <Label Text="{Binding TimeStamp}"
                                                                                   TextColor="DarkGray"
                                                                                   FontSize="9"
                                                                                   FontAttributes="Bold"
                                                                                   VerticalOptions="End"
