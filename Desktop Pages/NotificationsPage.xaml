                                </ScrollView>
                            </Grid>
                        </tabView:SfTabItem.Content>
                    </tabView:SfTabItem>

                    <tabView:SfTabItem Header="Parents">
                        <tabView:SfTabItem.Content>
                            <Grid BackgroundColor="Transparent"
                                  Margin="0,45,29,0">
                                <ScrollView>
                                    <VerticalStackLayout>
                                        <CollectionView x:Name="collectionViewAllParents"
                                                        SelectionMode="Single"
                                                        SelectionChanged="collectionViewAllParents_SelectionChanged"
                                                        ItemSizingStrategy="MeasureAllItems"
                                                        Margin="0,0,20,0">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Vertical"
                                                                   ItemSpacing="10" />
                                            </CollectionView.ItemsLayout>
