<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:maui="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
             xmlns:expander="clr-namespace:Syncfusion.Maui.Expander;assembly=Syncfusion.Maui.Expander"
             xmlns:radialmenu="clr-namespace:Syncfusion.Maui.RadialMenu;assembly=Syncfusion.Maui.RadialMenu"
             x:Class="AdminApp.NotificationsPage"
             BackgroundColor="#93c2ec">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"
                            IsEnabled="False" />
    </Shell.BackButtonBehavior>

    <Grid>
        <BoxView BackgroundColor="#FFFFFF"
                 Margin="100,40,100,100"
                 CornerRadius="20"
                 Opacity="0.3">
        </BoxView>
        <BoxView BackgroundColor="#FFFFFF"
                 Margin="130,0,130,100"
                 CornerRadius="20"
                 Opacity="0.2">
        </BoxView>

        <Border BackgroundColor="#0e79d7"
                Stroke="#0e79d7"
                Margin="75,75,75,75"
                StrokeShape="RoundRectangle 20,20,20,20">
            <Grid ColumnDefinitions=".8*, .2*">
                <HorizontalStackLayout VerticalOptions="Start"
                                       Margin="75,10,0,0"
                                       Spacing="10">
                    <Label Text="Notifications"
                           VerticalOptions="Center"
                           FontSize="Header" />
                    <Image Source="notificationsheader.png"
                           HeightRequest="50" />
                </HorizontalStackLayout>
            </Grid>
        </Border>
        <Grid ColumnDefinitions=".5*,.5*">
            <Border BackgroundColor="Transparent"
                    Stroke="#f7f8fd"
                    Margin="135,165,75,100"
                    StrokeShape="RoundRectangle 20,0,20,0"
                    Grid.ColumnSpan="2">
                <Grid ColumnDefinitions=".55*,.45*"
                      BackgroundColor="#E0E0E0">
                    <Grid RowDefinitions=".225*,.1*,.675*"
                          RowSpacing="30">
                        <Border Grid.Row="0"
                                BackgroundColor="White"
                                Stroke="White"
                                Opacity="1">
                        </Border>
                        <CollectionView x:Name="collectionViewTypeItems"
                                        Grid.Row="0"
                                        Margin="0,15,0,15"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        SelectionMode="Single"
                                        SelectionChanged="collectionViewTypeItems_SelectionChanged">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="15" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#0e79d7"
                                            MinimumHeightRequest="50"
                                            MinimumWidthRequest="175"
                                            MaximumHeightRequest="75"
                                            StrokeShape="RoundRectangle 25">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke"
                                                                Value="DarkGray" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke"
                                                                Value="White" />
                                                        <Setter Property="Background"
                                                                Value="#BBDEFB" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                        <HorizontalStackLayout Spacing="5"
                                                               Margin="0,0,0,0"
                                                               HorizontalOptions="Center">
                                            <Image Source="{Binding Image}"
                                                   Aspect="AspectFit"
                                                   MaximumHeightRequest="25"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />
                                            <Label Text="{Binding Type}"
                                                   TextColor="White"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Grid Grid.Row="1">
                            <maui:SfTextInputLayout Hint="Title: "
                                                    IsHintAlwaysFloated="True"
                                                    Margin="0,-10,0,-40"
                                                    ContainerType="Outlined"
                                                    ContainerBackground="White"
                                                    Stroke="White"
                                                    FocusedStrokeThickness="0.4"
                                                    OutlineCornerRadius="0.1">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#FFFFFF" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Focused">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#0e79d7" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Error">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#B3261E" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Editor TextColor="Black"
                                        x:Name="editorTitle"
                                        IsSpellCheckEnabled="True"
                                        IsTextPredictionEnabled="True"
                                        Placeholder="Enter your text here..."
                                        PlaceholderColor="LightGray" />
                                <maui:SfTextInputLayout.HintLabelStyle>
                                    <maui:LabelStyle FontSize="18"
                                                     FontAttributes="Bold" />
                                </maui:SfTextInputLayout.HintLabelStyle>
                            </maui:SfTextInputLayout>
                        </Grid>
                        <Grid Grid.Row="2">
                            <maui:SfTextInputLayout Hint="Description: "
                                                    IsHintAlwaysFloated="True"
                                                    Margin="0,10,30,-40"
                                                    ContainerType="Outlined"
                                                    ContainerBackground="White"
                                                    Stroke="White"
                                                    FocusedStrokeThickness="0.4"
                                                    OutlineCornerRadius="0.1">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#FFFFFF" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Focused">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#0e79d7" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Error">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke"
                                                            Value="#B3261E" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Editor TextColor="Black"
                                        x:Name="editorDescription"
                                        AutoSize="TextChanges"
                                        IsSpellCheckEnabled="True"
                                        IsTextPredictionEnabled="True"
                                        Placeholder="Enter your text here..."
                                        PlaceholderColor="LightGray" />
                                <maui:SfTextInputLayout.HintLabelStyle>
                                    <maui:LabelStyle FontSize="18"
                                                     FontAttributes="Bold" />
                                </maui:SfTextInputLayout.HintLabelStyle>
                            </maui:SfTextInputLayout>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            <BoxView Grid.Column="1"
                     Margin="175,245,105,101"
                     Background="White"
                     Opacity="1">
            </BoxView>
            <BoxView Grid.Column="1"
                     Margin="200,166,76,120"
                     HeightRequest="50"
                     Background="White"
                     VerticalOptions="Start"
                     Opacity="1">
            </BoxView>
            <tabView:SfTabView x:Name="tabView"
                               Grid.Column="1"
                               Margin="200,166,76,100">
