                                                        <RowDefinition Height="48" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="35" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
